# Files excluded from the Vercel deployment upload (smaller bundle, faster builds).
#
# IMPORTANT: Do NOT list `deeptutor/`, `pyproject.toml`, `requirements/`, or `*.py`
# if you deploy the FastAPI backend on Vercel — the Python app must be present.
# For a Next.js–only deploy, set Project Root Directory to `web` in the Vercel
# dashboard so only the frontend is uploaded; this file still applies from repo root.

# Development & docs (keep README for npm/package metadata if needed)
*.md
!README.md
!CONTRIBUTING.md

# Environment (never ship secrets)
.env.local
.env.development
.env.test

# Local / CI testing (not needed at runtime)
tests/
.playwright/
playwright.config.ts
web/app/**/page.test.tsx

# Git metadata
.git

# Build outputs (regenerated on Vercel)
dist/
build/
coverage/
web/.next/

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# JS deps reinstalled via installCommand
node_modules/
web/node_modules/
npm-debug.log
yarn.lock
yarn-error.log
pnpm-lock.yaml

# Large optional trees (adjust if your deploy needs them)
assets/README/
documents/
data/

# Dev tooling scripts (not imported by deeptutor at runtime)
scripts/
