# Files excluded from the Vercel deployment upload (smaller bundle, faster builds).
#
# FRONTEND-ONLY DEPLOYMENT: This config excludes all Python backend files.
# If deploying FastAPI backend to Vercel as well, comment out the Python sections below.
# For Next.js–only deploy, Vercel Project Root should be set to `web` in dashboard.

# Documentation (keep README only for package metadata)
*.md
!README.md

# Environment (never ship secrets)
.env*
.env.local
.env.development
.env.test
.env.production

# Source control
.git
.gitignore
.github/

# Docker / Infrastructure (not needed for frontend)
Dockerfile
docker-compose*.yml
.dockerignore

# Python backend (EXCLUDE for frontend-only deployment)
deeptutor/
deeptutor_cli/
requirements/
requirements.txt
pyproject.toml
setup.py
*.py
.Python
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Testing & CI
tests/
.pytest_cache/
.coverage
coverage/
.playwright/
playwright.config.ts
web/app/**/page.test.tsx
web/tests/
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Build outputs (regenerated on Vercel)
dist/
build/
.next/
web/.next/
.turbo/

# IDE & OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.log

# Node modules (reinstalled by npm)
node_modules/
web/node_modules/
npm-debug.log
yarn.lock
yarn-error.log
pnpm-lock.yaml

# Large optional data & docs
documents/
data/
scripts/
assets/README/
assets/releases/
assets/roster/

# Dev utilities
streamlit_auth/
bot.py
CONTRIBUTING.md
CITATION.cff
FIX_NO_KEY_ERROR.md
IMPLEMENTATION_COMPLETE.md
NO_KEY_ERROR_FIXED.md
QUICK_REFERENCE.md
RUN.md
SKILL.md
AGENTS.md
CHANGES_DETAILED.md
FRESH_REPOSITORY_INSTRUCTIONS.md
VERCEL_OPTIMIZATION.md

