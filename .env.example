# =====================================================================
# DeepTutor Environment Template
# =====================================================================
# Copy this file to `.env` and fill in your values.
#
# Quick local start (Ollama, no cloud keys): see the "Local-first preset"
# block at the end of this file, or docs/run.md.
#
# Sections:
#   1. Ports
#   2. LLM                       (required for chat)
#   3. Embedding                 (required for knowledge base / RAG)
#   4. Web Search                (optional)
#   5. Networking & CORS         (Docker / remote deployments)
#   6. Security
#   7. Authentication & Multi-User
#   8. PocketBase sidecar        (optional auth + storage)
#   9. Storage / Attachments     (optional)
#  10. Razorpay payments (optional)
#  11. HiDream image generation (optional — external CUDA server)
#
# No payment method on file? Use the copy-paste preset in docs/run.md
# ("Free stack — no credit card"): HF Router chat + DuckDuckGo search +
# Ollama or Gemini embeddings.
#
# Only LLM_* are strictly required to start the app. Everything else has
# sensible defaults — uncomment and set only what you actually need.

# ---------------------------------------------------------------------
# 1. Ports
# ---------------------------------------------------------------------
BACKEND_PORT=8001
# Used by docker-compose to expose the optional PocketBase sidecar. The
# Python backend itself reaches PocketBase via POCKETBASE_URL below.
POCKETBASE_PORT=8090

# ---------------------------------------------------------------------
# 2. LLM (Required)
# ---------------------------------------------------------------------
# Supported bindings: huggingface, ollama, vllm, openai, anthropic, deepseek, gemini, azure_openai,
# nvidia_nim, lm_studio, ollama, vllm, openrouter, siliconflow, dashscope, ...
# Full list: `deeptutor provider list`.
LLM_BINDING=vllm
LLM_MODEL=Qwen/Qwen3.5-35B-A3B
LLM_API_KEY=sk-no-key-required
LLM_HOST=http://localhost:8000/v1
#
# Optional: same OpenAI-compatible host (e.g. Groq) but a smaller model id when
# the primary returns HTTP 429 / daily token limits. One immediate retry.
# If unset, common ids still auto-fallback (e.g. llama-3.3-70b-versatile → llama-3.1-8b-instant).
# LLM_RATE_LIMIT_FALLBACK_MODEL=llama-3.1-8b-instant
#
# Practice Center (MCQ) default model on Groq is llama-3.1-8b-instant so it does not
# share the main LLM_MODEL. Override with any id your host accepts:
# LLM_MODEL_PRACTICE=llama-3.1-8b-instant
# Code lab (generated problems) uses the same defaults unless overridden:
# LLM_MODEL_CODING_PRACTICE=llama-3.1-8b-instant
#
# Code lab C/C++ on Windows: if gcc/clang are not on PATH, install LLVM, MSYS2
# MinGW-w64, or point to a compiler explicitly:
# DEEPTUTOR_CC=C:\msys64\mingw64\bin\gcc.exe
# DEEPTUTOR_CXX=C:\msys64\mingw64\bin\g++.exe
#
# Code lab exam: allow "Bypass suspension (testing)" API (default on unless ENVIRONMENT=production)
# DEEPTUTOR_CODE_LAB_DEV_BYPASS=1
#
# --- Hugging Face Inference (optional alternative to OpenAI) ---
# HF_TOKEN is preferred; these are equivalent for the OpenAI-compatible router & CLI:
#   HF_API_TOKEN, HF_ACCESS_TOKEN, HUGGINGFACE_HUB_TOKEN, HUGGING_FACE_HUB_TOKEN,
#   HUGGINGFACE_TOKEN
# (Never commit token values; use .env only.)
HF_TOKEN=
# Force the Hugging Face OpenAI-compatible router even if a placeholder OpenAI
# key is present in the catalog (set to 1 for the free HF-only preset in docs/run.md).
# LLM_USE_HF_ROUTER=1
# If OPENAI_API_KEY is unset but HF_TOKEN is set, DeepTutor routes chat to the
# HF OpenAI-compatible gateway (see provider_registry / gateway detection).
# Set an explicit HF-hosted model id (from huggingface.co) — examples:
#   HF_DEFAULT_LLM_MODEL=Qwen/Qwen3.5-35B-A3B
#   HF_DEFAULT_LLM_MODEL=deepseek-ai/DeepSeek-Coder-V2-Instruct
#   HF_DEFAULT_LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# Override base URL only if Hugging Face documents a different router endpoint.
# HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HF_DEFAULT_LLM_MODEL=Qwen/Qwen3.5-35B-A3B
#
# --- Multi-model AI Tutor — per-intent model overrides (optional) ---
# The AI Tutor router automatically picks the best model for each query type.
# Override any intent→model mapping with these vars (HF model IDs):
#   GENERAL tutor:   Qwen/Qwen3.5-35B-A3B                   (default)
#   CODING mentor:   deepseek-ai/DeepSeek-Coder-V2-Instruct (default)
#   MATH / logic:    deepseek-ai/deepseek-math-7b-instruct  (default)
#   CAREER agent:    Qwen/Qwen3.5-35B-A3B                   (default)
#   ASSESSMENT:      Qwen/Qwen3.5-35B-A3B                   (default)
#   SAFETY guard:    meta-llama/Llama-Guard-3-8B            (default)
#   VISION (VL):     Qwen/Qwen3.5-35B-A3B                   (default)
#   OCR:             naver-clova-ix/donut-base              (default)
#   SPEECH:          openai/whisper-large-v3                (default)
HF_MODEL_GENERAL=
HF_MODEL_CODING=
HF_MODEL_MATH=
HF_MODEL_CAREER=
HF_MODEL_ASSESSMENT=
HF_MODEL_SAFETY=
HF_MODEL_VISION=
HF_MODEL_VL=
HF_MODEL_OCR=
HF_MODEL_SPEECH=
# Strict mode: require self-hosted inference and skip hosted HF fallback.
# For Hugging Face free-tier chat, set this to false and use HF_TOKEN (docs/run.md).
SELF_HOSTED_ONLY=true
# Per-intent server overrides (optional):
# ROUTER_GENERAL_BASE_URL=http://localhost:8000/v1
# ROUTER_CODING_BASE_URL=http://localhost:8001/v1
# ROUTER_MATH_BASE_URL=http://localhost:8002/v1
# ROUTER_VISION_BASE_URL=http://localhost:8003/v1
# ROUTER_OCR_BASE_URL=http://localhost:8004/v1
# ROUTER_SPEECH_BASE_URL=http://localhost:8005/v1
# ROUTER_SAFETY_BASE_URL=http://localhost:8006/v1
# ROUTER_CAREER_BASE_URL=http://localhost:8000/v1
# ROUTER_ASSESSMENT_BASE_URL=http://localhost:8000/v1
#
# Shared backend endpoints (router auto-picks first available):
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=sk-no-key-required
TGI_BASE_URL=
TGI_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
LLAMACPP_BASE_URL=
LLAMACPP_API_KEY=
FASTAPI_INFERENCE_BASE_URL=
FASTAPI_INFERENCE_API_KEY=
#
# Speech (Whisper large-v3) — timeout in seconds (default 120)
HF_SPEECH_TIMEOUT=
# Safety moderation (Llama Guard 3) — timeout in seconds (default 30)
HF_SAFETY_TIMEOUT=
# Required for Azure OpenAI; leave blank otherwise.
LLM_API_VERSION=
# Optional: control reasoning / thinking effort.
#   DeepSeek:        "high" or "max" enables thinking; "minimal" disables.
#   OpenAI o-series: "low", "medium", "high".
# Leave empty to auto-detect from the model name.
LLM_REASONING_EFFORT=

# ---------------------------------------------------------------------
# 3. Embedding (Required for knowledge base / RAG)
# ---------------------------------------------------------------------
# Zero API spend (pick one):
#   • Ollama locally: `ollama pull nomic-embed-text` then binding ollama below
#     (see deeptutor/services/embedding/.env.example).
#   • Gemini: free-tier key from Google AI Studio → EMBEDDING_BINDING=gemini,
#     EMBEDDING_HOST=https://generativelanguage.googleapis.com/v1beta/openai/embeddings,
#     GEMINI_API_KEY=…, EMBEDDING_MODEL=gemini-embedding-001
#
# Supported bindings: openai, azure_openai, cohere, jina, ollama, vllm,
# siliconflow, aliyun, gemini, custom.
#
# IMPORTANT (v1.3.0+): EMBEDDING_HOST is the FULL endpoint URL — it is
# called verbatim, no path is appended. (LLM_HOST above remains a
# chat-completions base URL.) Examples:
#   OpenAI:       https://api.openai.com/v1/embeddings
#   Gemini:       https://generativelanguage.googleapis.com/v1beta/openai/embeddings
#   Cohere v4:    https://api.cohere.com/v2/embed
#   Jina:         https://api.jina.ai/v1/embeddings
#   Ollama:       http://localhost:11434/api/embed
#   SiliconFlow:  https://api.siliconflow.cn/v1/embeddings
#   Aliyun:       https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
EMBEDDING_BINDING=vllm
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_API_KEY=sk-no-key-required
EMBEDDING_HOST=http://localhost:8003/v1/embeddings
# Required for Azure embedding deployments; leave blank otherwise.
EMBEDDING_API_VERSION=
# Leave EMBEDDING_DIMENSION empty to let DeepTutor auto-fill it from the
# provider's response on the first successful "Test connection". Override
# only when you need to force a specific Matryoshka dim (e.g. Qwen3-Embedding
# 1024/1536/2048/2560/4096, OpenAI text-embedding-3-large 3072).
EMBEDDING_DIMENSION=
# Whether to send the `dimensions` request parameter to the embedding endpoint:
#   true             -> always send  (OpenAI text-embedding-3*, Qwen3-Embedding,
#                                     Qwen3-VL-Embedding)
#   false            -> never send   (set this if your provider returns HTTP 400
#                                     when `dimensions` is present)
#   <empty> / unset  -> auto-detect from the model family.
EMBEDDING_SEND_DIMENSIONS=

# Per-provider API-key fallbacks. Used when the active embedding profile in
# the catalog has no api_key set; the Settings UI also pre-fills these on
# first launch so you don't have to retype them.
SILICONFLOW_API_KEY=
DASHSCOPE_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=
GEMINI_API_KEY=
# Google AI Studio / Gemini often document this key name; DeepTutor treats it as
# an alias for GEMINI_API_KEY when resolving chat + embeddings.
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_API_KEY=

# ⚠️  Docker + local LLM (LM Studio / Ollama / vLLM)
# ────────────────────────────────────────────────────────────────────
# When running DeepTutor in Docker and your LLM/embedding model runs on
# the HOST machine:
#   - Do NOT use "localhost" or "127.0.0.1" — inside the container these
#     refer to the container itself, not the host.
#   - macOS / Windows Docker Desktop:
#       http://host.docker.internal:<port>/v1
#   - Linux: use the host's LAN IP (e.g. http://192.168.1.100:<port>/v1)
#     or run Docker with --network=host.
#
# Example (LM Studio on port 1234):
#   LLM_BINDING=lm_studio
#   LLM_HOST=http://host.docker.internal:1234/v1
#   EMBEDDING_BINDING=lm_studio
#   EMBEDDING_HOST=http://host.docker.internal:1234/v1/embeddings

# ---------------------------------------------------------------------
# 4. Web Search (Optional)
# ---------------------------------------------------------------------
# Providers: brave, tavily, serper, jina, perplexity, searxng, duckduckgo.
# duckduckgo — no SEARCH_API_KEY (rate-limited; fine for dev / light use).
SEARCH_PROVIDER=
SEARCH_API_KEY=
# Required for self-hosted SearXNG instances; optional override for other
# providers that need an explicit base URL.
SEARCH_BASE_URL=
# Optional HTTP/HTTPS proxy for outbound search traffic.
SEARCH_PROXY=

# ---------------------------------------------------------------------
# 5. Networking & CORS (Docker / remote deployments)
# ---------------------------------------------------------------------
# Optional extra origin(s) appended to the FastAPI CORS allowlist (e.g. a
# custom domain). Use CORS_ORIGINS for comma/newline-separated lists.
# localhost / 127.0.0.1 are always allowed. When AUTH_ENABLED=false,
# other http(s) browser origins are allowed for local/single-user Docker use.
CORS_ORIGIN=
CORS_ORIGINS=

# ---------------------------------------------------------------------
# 6. Security
# ---------------------------------------------------------------------
# Skip TLS verification for outbound HTTP. Keep this false in production —
# only flip it on for local self-signed certs or air-gapped testing.
DISABLE_SSL_VERIFY=false

# ---------------------------------------------------------------------
# 7. Authentication & Multi-User
# ---------------------------------------------------------------------
# Set AUTH_ENABLED=true to require login when hosting publicly. Leave as
# false for local/localhost usage — no login needed.
AUTH_ENABLED=false

# JWT signing secret. If blank, DeepTutor creates and reuses a stable
# local secret at multi-user/_system/auth/auth_secret. Set explicitly for
# production (especially across multiple workers). Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=

# Login session lifetime in hours.
AUTH_TOKEN_EXPIRE_HOURS=24

# Set to true when serving over HTTPS so the auth cookie is marked Secure.
AUTH_COOKIE_SECURE=false

# When true (with local multi-user auth, not PocketBase), admins who have
# enabled TOTP via GET/POST /api/v1/auth/mfa/enroll and activate must pass
# the current code in header X-Admin-MFA on every admin API request.
AUTH_ADMIN_MFA_REQUIRED=false

# --- Multi-user setup (recommended) ---
# With AUTH_ENABLED=true and no AUTH_USERNAME / AUTH_PASSWORD_HASH set,
# register the first account via POST /api/v1/auth/register. The first user
# automatically becomes admin and can manage other users from
# /admin/users; the public /register endpoint closes itself after the
# first admin exists. Users are stored in
# multi-user/_system/auth/users.json.

# --- Single-user env-var setup (legacy / simple) ---
# Alternatively, set AUTH_USERNAME and AUTH_PASSWORD_HASH directly. This
# user is always treated as admin. When multi-user/_system/auth/users.json
# exists, it takes priority and these env vars are ignored.

# Username for the single admin account (single-user mode only).
AUTH_USERNAME=

# Bcrypt hash of the password. Generate with:
#   python -c "from deeptutor.services.auth import hash_password; print(hash_password('yourpassword'))"
AUTH_PASSWORD_HASH=

# --- Google Sign-In (OAuth code exchange) ---
# POST /api/v1/auth/oauth/google/callback exchanges ``code`` for a session.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=

# --- Firebase ---
# POST /api/v1/auth/firebase verifies ID tokens (requires firebase-admin).
# FIREBASE_PROJECT_ID=your-project-id

# ---------------------------------------------------------------------
# 8. PocketBase sidecar (Optional auth + storage)
# ---------------------------------------------------------------------
# Leave POCKETBASE_URL blank to use the built-in SQLite/JSON backend
# (default). Set it to route auth, sessions, and KB storage through
# PocketBase instead.
#
# When running via docker compose, PocketBase is always started; it is
# only used by the backend if POCKETBASE_URL is set here.
#
# NOTE: PocketBase mode is currently SINGLE-USER ONLY. The default schema
# has no `role` field on `users` (every login resolves to role=user, no
# admin), and session/message/turn queries are not filtered by user_id.
# Multi-user deployments must keep POCKETBASE_URL blank and use the
# default JSON/SQLite backend.
#
#   Local Docker:  POCKETBASE_URL=http://pocketbase:8090
#   Local bare:    POCKETBASE_URL=http://localhost:8090
POCKETBASE_URL=

# Admin credentials used by the Python backend to manage PocketBase
# collections. Set these after creating your admin in the PocketBase UI.
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# Public PocketBase URL for OAuth redirects (remote server deployments).
# Leave blank when browsing from the same machine running Docker.
POCKETBASE_EXTERNAL_URL=

# ---------------------------------------------------------------------
# 9. Storage / Attachments (Optional)
# ---------------------------------------------------------------------
# Where the chat turn runtime persists user-uploaded files (PDF, DOCX,
# images, …) so the preview drawer can re-fetch the originals after the
# in-memory base64 is dropped.
#
# Defaults to <project>/data/user/workspace/chat/attachments, which is
# already mounted as a volume in docker-compose.yml — leave blank for
# the standard Docker / Linux deployment. Override only when running
# multiple backend instances against shared storage (e.g. NFS).
CHAT_ATTACHMENT_DIR=

# ---------------------------------------------------------------------
# 10. Razorpay (Optional — subscriptions / one-time checkout)
# ---------------------------------------------------------------------
# Create orders and verify payments server-side. Never expose RAZORPAY_KEY_SECRET
# RAZORPAY_MERCHANT_ID is optional (e.g. internal merchant / route id stored in order notes).
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_MERCHANT_ID=

# ---------------------------------------------------------------------
# 11. HiDream-O1-Image (Optional — local CUDA Flask server)
# ---------------------------------------------------------------------
# DeepTutor proxies text-to-image to the upstream HiDream repo ``app.py``.
# Download weights separately (HF_TOKEN / huggingface-cli); never commit tokens.
#
#   HIDREAM_SERVICE_URL=http://127.0.0.1:7860
#
# Optional: Bearer token if you terminate TLS/auth in front of Flask.
# HIDREAM_SERVICE_TOKEN=
#
# Optional: generation timeout in seconds (default 900).
# HIDREAM_SERVICE_TIMEOUT=

# ---------------------------------------------------------------------
# 12. ClickHouse (Optional — domain_events warehouse)
# ---------------------------------------------------------------------
# Start the sidecar: docker compose --profile analytics up -d
# Point the API at it (same Docker network as ``deeptutor``):
#   CLICKHOUSE_ENABLED=true
#   CLICKHOUSE_HOST=clickhouse
#   CLICKHOUSE_HTTP_PORT=8123
#   CLICKHOUSE_USER=default
#   CLICKHOUSE_PASSWORD=
#   CLICKHOUSE_DATABASE=deeptutor
#
# A background task flushes unexported rows from SQLite every 30s.
# CLICKHOUSE_ENABLED=false

# ---------------------------------------------------------------------
# 13. Neo4j (Optional — milestone prerequisite graph)
# ---------------------------------------------------------------------
# Same profile as ClickHouse: docker compose --profile analytics up -d
#   NEO4J_ENABLED=true
#   NEO4J_URI=bolt://neo4j:7687
#   NEO4J_USER=neo4j
#   NEO4J_PASSWORD=changeme
#
# NEO4J_AUTH in compose defaults to neo4j/changeme — match NEO4J_PASSWORD.
# NEO4J_ENABLED=false

# =====================================================================
# Local-first preset (optional — copy these lines into .env for Ollama)
# =====================================================================
#   ollama serve
#   ollama pull llama3.2:3b-instruct
#   ollama pull nomic-embed-text
#
# LLM_BINDING=ollama
# LLM_MODEL=llama3.2:3b-instruct
# LLM_API_KEY=sk-no-key-required
# LLM_HOST=http://localhost:11434/v1
# EMBEDDING_BINDING=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_API_KEY=
# EMBEDDING_HOST=http://localhost:11434/api/embed
# EMBEDDING_DIMENSION=768
# EMBEDDING_SEND_DIMENSIONS=false
# SEARCH_PROVIDER=duckduckgo
# SEARCH_API_KEY=

# =====================================================================
# Hugging Face + Qwen3.5 preset (cloud inference — copy into .env)
# =====================================================================
# Create a fine-grained token at huggingface.co/settings/tokens with
# repo.content.read (and gated models you need). Never commit the token.
#
# LLM_BINDING=huggingface
# LLM_MODEL=Qwen/Qwen3.5-35B-A3B
# LLM_API_KEY=
# LLM_HOST=https://router.huggingface.co/v1
# HF_TOKEN=
# HF_DEFAULT_LLM_MODEL=Qwen/Qwen3.5-35B-A3B
# HF_MODEL_CHAT=Qwen/Qwen3.5-35B-A3B
# HF_MODEL_TUTORBOT=Qwen/Qwen3.5-35B-A3B
# HF_MODEL_VISION=Qwen/Qwen3.5-35B-A3B
# HF_MODEL_GENERAL=Qwen/Qwen3.5-35B-A3B
# SELF_HOSTED_ONLY=false
# LLM_USE_HF_ROUTER=1
